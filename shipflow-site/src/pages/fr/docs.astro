---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import NavBar from "../../components/NavBar.astro";
import { pathFor } from "../../i18n/ui";

const locale = "fr";

const coreDocs = [
  ["AGENT.md (compat)", "Où un nouvel agent doit regarder en premier selon la tâche."],
  ["shipflow_data/technical/context.md", "Comment s’orienter vite dans le dépôt, repérer les zones sensibles et router les modifications."],
  ["shipflow_data/technical/context-function-tree.md", "Comment naviguer dans de grands fichiers shell procéduraux sans tout relire."],
  ["shipflow_data/editorial/content-map.md", "Où vit le contenu : docs, landing pages, clusters sémantiques, surfaces publiques et destinations de repurposing."],
  ["skills/references/decision-quality-contract.md", "Pourquoi ShipFlow choisit correction, sécurité, maintenabilité, performance pertinente et preuve avant vitesse ou commodité."],
  ["docs/skill-launch-cheatsheet.md", "Référence Markdown pour les skills maîtres, les skills de support et les modes d’arguments."],
  ["docs/focus-tags-cheatsheet.md", "Cheatsheet publique pour les tags de recentrage légers comme #partner, #growth, #end-user et #shipflow."],
  ["README.md (compat)", "Vue d’ensemble publique, positionnement, onboarding et histoire framework de haut niveau."],
  ["shipflow-spec-driven-workflow.md", "Doctrine d’exécution derrière sf-spec, sf-ready, sf-start et sf-verify."]
];

const decisionDocs = [
  ["shipflow_data/business/business.md", "Pour qui le produit existe, quelle valeur il crée et quel modèle il peut soutenir."],
  ["shipflow_data/business/product.md", "Ce que fait le produit, quels workflows comptent et quels non-objectifs doivent rester dehors."],
  ["shipflow_data/business/branding.md", "Comment le produit doit parler, ce qu’il peut revendiquer et comment la confiance se gagne."],
  ["shipflow_data/business/gtm.md", "Comment le produit est présenté publiquement, quelles objections comptent et quelles preuves le soutiennent."],
  ["shipflow_data/technical/architecture.md", "Comment le système est organisé, où sont les frontières et quels invariants tiennent."],
  ["shipflow_data/technical/guidelines.md", "Comment contribuer dans le dépôt et quelles règles techniques restent stables."]
];
---

<BaseLayout
  title="Docs ShipFlow | Navigation et contrats"
  description="Point d’entrée documentaire de ShipFlow : couche de contexte, doctrine de workflow et contrats de décision."
  locale={locale}
  canonicalPath="/fr/docs"
  alternatePath="/docs"
>
  <main class="page-shell">
    <NavBar locale={locale} currentPath="/docs" />

    <section class="section" id="artifact-corpus">
      <div class="section-heading">
        <p class="eyebrow">Vue d’ensemble des docs</p>
        <h1 class="page-title">Les docs sont conçues pour l’orientation rapide des agents, pas pour l’accumulation encyclopédique.</h1>
        <p>
          La documentation ShipFlow est structurée pour qu’un nouvel agent
          trouve le bon contexte, comprenne la surface de décision et exécute
          face à des contrats explicites plutôt que deviner depuis l’historique
          du chat.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="doc-grid">
        <article class="doc-card">
          <h3>La qualité est un contrat, pas une humeur</h3>
          <p>
            ShipFlow porte un contrat explicite de qualité de décision. Les
            agents doivent préférer un travail professionnel borné aux
            raccourcis, et traiter vitesse ou coût comme des critères de départage.
          </p>
          <a class="doc-action" href="#decision-contracts">Lire les contrats de décision</a>
        </article>

        <article class="doc-card">
          <h3>Aide au lancement des skills</h3>
          <p>
            La page de modes explique quel skill maître lancer, quels skills
            ciblés possèdent les voies de preuve et quels arguments changent un
            workflow au lieu de décrire la tâche.
          </p>
          <a class="doc-action" href={pathFor("/skill-modes", locale)}>Ouvrir l’aide</a>
        </article>

        <article class="doc-card">
          <h3>Tags de recentrage rapides</h3>
          <p>
            Si une conversation dérive, ShipFlow accepte maintenant des tags de
            recentrage légers comme <code>#partner</code>,
            <code>#growth</code>, <code>#end-user</code>,
            <code>#quality</code> et <code>#shipflow</code> pour recharger le
            bon contrat sans relancer tout un workflow.
          </p>
          <a class="doc-action" href="https://github.com/dianedef/ShipFlow/blob/main/docs/focus-tags-cheatsheet.md">Ouvrir la cheatsheet</a>
        </article>

        <article class="doc-card">
          <h3>Installer proprement le plugin Codex</h3>
          <p>
            Si vous voulez le chemin utilisateur le plus court, la page
            d’installation montre la commande marketplace, l’étape dans le
            répertoire des plugins et la première commande à lancer ensuite.
          </p>
          <a class="doc-action" href={pathFor("/install", locale)}>Voir l’installation</a>
        </article>

        <article class="doc-card">
          <h3>Questions fréquentes</h3>
          <p>
            Pour une version directe, la FAQ couvre les questions récurrentes
            sur la portée documentaire, les skills et le comportement du
            framework.
          </p>
          <a class="doc-action" href={pathFor("/faq", locale)}>Ouvrir la FAQ</a>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Navigation centrale</p>
        <h2>Commencez ici quand vous devez vous orienter.</h2>
      </div>

      <div class="doc-grid">
        {coreDocs.map(([name, body]) => (
          <article class="doc-card">
            <h3>{name}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="decision-contracts">
      <div class="section-heading">
        <p class="eyebrow">Contrats de décision</p>
        <h2>Chaque document a un rôle explicite.</h2>
        <p>
          Business, produit, marque, GTM, architecture et guidelines restent
          séparés volontairement. Cette séparation évite les doublons, le
          contexte périmé et les contrats contradictoires.
        </p>
      </div>

      <div class="doc-grid">
        {decisionDocs.map(([name, body]) => (
          <article class="doc-card">
            <h3>{name}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="cta-panel">
        <p class="eyebrow">Logique d’exécution</p>
        <h2>Utilisez les docs comme des contrats produit, pas comme des notes passives.</h2>
        <p>
          La couche de contexte dit à l’agent où commencer. Les contrats de
          décision disent ce qui compte. La doctrine de workflow dit comment
          passer de la réduction d’ambiguïté à une livraison vérifiée.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={pathFor("/skills", locale)}>Explorer les skills</a>
          <a class="button button-secondary" href={pathFor("/skill-modes", locale)}>Lire l’aide au lancement</a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
