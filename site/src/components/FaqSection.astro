---
import { pathFor, sharedHomeSections, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].faq;
---

<section class="section" id="faq">
  <div class="section-heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>
      {copy.bodyPrefix}
      <a href={pathFor("/skill-modes", locale)}>{copy.bodyMiddle}</a>{copy.bodySuffix}
      <a href={pathFor("/faq", locale)}>{copy.bodyEnd}</a>.
    </p>
  </div>

  <div class="faq-list">
    {
      copy.items.map(([q, a]) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <p>{a}</p>
        </details>
      ))
    }
  </div>
</section>
