---
import { roleMapCopy, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = roleMapCopy[locale];
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <div class="role-list">
    {
      copy.docs.map(([name, role]) => (
        <div class="role-row">
          <code>{name}</code>
          <span>{role}</span>
        </div>
      ))
    }
  </div>
</section>
