---
import { sharedHomeSections, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].pricing;
---

<section class="section" id="pricing-hypothesis">
  <div class="section-heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <div class="card-grid">
    {copy.cards.map(([title, body]) => (
      <article class="card">
        <h3>{title}</h3>
        <p>{body}</p>
      </article>
    ))}
  </div>
</section>
