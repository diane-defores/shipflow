---
import { sharedHomeSections, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].proof;
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <div class="pill-grid">
    {copy.pills.map((pill) => <span class="pill">{pill}</span>)}
  </div>
</section>
