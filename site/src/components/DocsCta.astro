---
import { pathFor, sharedHomeSections, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].docs;
---

<section class="section" id="docs-cta">
  <div class="docs-panel">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2>{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="docs-links">
      {copy.links.map(([label, href]) => <a class="docs-link" href={pathFor(href, locale)}>{label}</a>)}
    </div>
  </div>
</section>
