---
import { pathFor, sharedHomeSections, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].cta;
---

<section class="section">
  <div class="cta-panel">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
    <div class="hero-actions">
      {copy.actions.map(([label, href, className]) => <a class={className} href={pathFor(href, locale)}>{label}</a>)}
    </div>
  </div>
</section>
