---
import { alternatePath, navCopy, pathFor, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = "en", currentPath = "/" } = Astro.props;
const copy = navCopy[locale];
const otherLocale = locale === "fr" ? "en" : "fr";
---

<header class="topbar">
  <a class="brand" href={pathFor("/", locale)}>
    <span class="brand-mark">SF</span>
    <span>ShipFlow</span>
  </a>

  <nav class="topnav" aria-label={copy.aria}>
    {copy.links.map(([label, href]) => <a href={pathFor(href, locale)}>{label}</a>)}
  </nav>

  <a class="button button-secondary topbar-cta" href="https://github.com/dianedef/ShipFlow">
    {copy.github}
  </a>
  <a class="language-link" href={alternatePath(currentPath, otherLocale)} hreflang={otherLocale}>
    {copy.language}
  </a>
</header>
