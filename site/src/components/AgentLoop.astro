---
import { homeCopy, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = homeCopy[locale].agentLoop;
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <div class="card-grid">
    {
      copy.items.map(([step, title, body]) => (
        <article class="card loop-card">
          <span>{step}</span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))
    }
  </div>
</section>
